                        "description": "Ejemplo de envío masivo a 20 usuarios. Se procesarán en lotes de 10."
                    },
                    "response": []
                },
                {
                    "name": "⭐ Enviar a TODOS los suscriptores activos (AUTO)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}",
                                "description": "Token JWT del admin"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/marketing/send-migration-notification-to-active-subscribers",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "marketing",
                                "send-migration-notification-to-active-subscribers"
                            ]
                        },
                        "description": "🚀 RECOMENDADO: Envía email de notificación de migración automáticamente a TODOS los usuarios con suscripción activa. No requiere body - obtiene los usuarios directamente de la base de datos y elimina duplicados."
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3001/v1",
            "type": "string"
        },
        {
            "key": "jwt_token",
            "value": "",
            "type": "string"
        }
    ]
}