                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}",
                                "description": "Token JWT del admin"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"recipients\": [\n    {\"email\": \"usuario1@example.com\", \"name\": \"Usuario 1\"},\n    {\"email\": \"usuario2@example.com\", \"name\": \"Usuario 2\"},\n    {\"email\": \"usuario3@example.com\", \"name\": \"Usuario 3\"},\n    {\"email\": \"usuario4@example.com\", \"name\": \"Usuario 4\"},\n    {\"email\": \"usuario5@example.com\", \"name\": \"Usuario 5\"},\n    {\"email\": \"usuario6@example.com\", \"name\": \"Usuario 6\"},\n    {\"email\": \"usuario7@example.com\", \"name\": \"Usuario 7\"},\n    {\"email\": \"usuario8@example.com\", \"name\": \"Usuario 8\"},\n    {\"email\": \"usuario9@example.com\", \"name\": \"Usuario 9\"},\n    {\"email\": \"usuario10@example.com\", \"name\": \"Usuario 10\"},\n    {\"email\": \"usuario11@example.com\", \"name\": \"Usuario 11\"},\n    {\"email\": \"usuario12@example.com\", \"name\": \"Usuario 12\"},\n    {\"email\": \"usuario13@example.com\", \"name\": \"Usuario 13\"},\n    {\"email\": \"usuario14@example.com\", \"name\": \"Usuario 14\"},\n    {\"email\": \"usuario15@example.com\", \"name\": \"Usuario 15\"},\n    {\"email\": \"usuario16@example.com\", \"name\": \"Usuario 16\"},\n    {\"email\": \"usuario17@example.com\", \"name\": \"Usuario 17\"},\n    {\"email\": \"usuario18@example.com\", \"name\": \"Usuario 18\"},\n    {\"email\": \"usuario19@example.com\", \"name\": \"Usuario 19\"},\n    {\"email\": \"usuario20@example.com\", \"name\": \"Usuario 20\"}\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/marketing/send-migration-notification",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
