{
    "info": {
        "_postman_id": "migration-notification-001",
        "name": "Migration Notification - Club Carvajal Fit",
        "description": "Colección para enviar notificaciones de migración masivas a usuarios",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login Admin",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200 || pm.response.code === 201) {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.environment.set(\"jwt_token\", jsonData.access_token || jsonData.token);",
                                    "    console.log(\"Token guardado:\", jsonData.access_token || jsonData.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@carvajalfit.com\",\n  \"password\": \"tu_password_aqui\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Login como administrador para obtener el token JWT"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Migration Notification",
            "item": [
                {
                    "name": "Enviar a un solo usuario",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}",
                                "description": "Token JWT del admin"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"recipients\": [\n    {\n      \"email\": \"usuario@example.com\",\n      \"name\": \"Juan Pérez\"\n    }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/marketing/send-migration-notification",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "marketing",
                                "send-migration-notification"
                            ]
                        },
                        "description": "Envía email de notificación de migración a un solo usuario"
                    },
                    "response": []
                },
                {
                    "name": "Enviar a múltiples usuarios",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}",
                                "description": "Token JWT del admin"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"recipients\": [\n    {\n      \"email\": \"usuario1@example.com\",\n      \"name\": \"Juan Pérez\"\n    },\n    {\n      \"email\": \"usuario2@example.com\",\n      \"name\": \"María González\"\n    },\n    {\n      \"email\": \"usuario3@example.com\",\n      \"name\": \"Carlos Rodríguez\"\n    },\n    {\n      \"email\": \"usuario4@example.com\",\n      \"name\": \"Ana Martínez\"\n    },\n    {\n      \"email\": \"usuario5@example.com\",\n      \"name\": \"Pedro López\"\n    }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/marketing/send-migration-notification",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "marketing",
                                "send-migration-notification"
                            ]
                        },
                        "description": "Envía email de notificación de migración a múltiples usuarios"
                    },
                    "response": []
                },
